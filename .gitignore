```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Logs and temporary files
*.log
*.tmp

# Environment files
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# MyPy cache
.mypy_cache/
.dmypy.json
dmypy.json

# Pytest cache
.pytest_cache/

# VSCode files
.vscode/settings.json
```